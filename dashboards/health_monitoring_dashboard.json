{
  "dashboard": {
    "title": "System Health Monitoring",
    "description": "Real-time health status of trading bot components and Kubernetes probes",
    "tags": ["health", "kubernetes", "monitoring", "probes"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Overall System Status",
        "type": "stat",
        "datasource": "Prometheus",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 0,
          "y": 0
        },
        "targets": [
          {
            "expr": "health_status_code",
            "refId": "A",
            "legendFormat": "Status (0=healthy, 1=degraded, 2=unhealthy)"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "area",
          "justifyMode": "center",
          "orientation": "auto",
          "textMode": "value_and_name",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "green",
                "value": 0
              }
            ]
          }
        }
      },
      {
        "id": 2,
        "title": "Ready to Accept Traffic",
        "type": "stat",
        "datasource": "Prometheus",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 6,
          "y": 0
        },
        "targets": [
          {
            "expr": "health_ready",
            "refId": "A",
            "legendFormat": "Ready (1=ready, 0=not ready)"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "area",
          "justifyMode": "center",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      {
        "id": 3,
        "title": "Process Liveness",
        "type": "stat",
        "datasource": "Prometheus",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 12,
          "y": 0
        },
        "targets": [
          {
            "expr": "health_alive",
            "refId": "A",
            "legendFormat": "Alive (1=alive, 0=dead)"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "area",
          "justifyMode": "center",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      {
        "id": 4,
        "title": "Uptime (Hours)",
        "type": "stat",
        "datasource": "Prometheus",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 18,
          "y": 0
        },
        "targets": [
          {
            "expr": "health_uptime_seconds / 3600",
            "refId": "A",
            "legendFormat": "Hours"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "center",
          "unit": "short"
        }
      },
      {
        "id": 5,
        "title": "Component Health Status",
        "type": "table",
        "datasource": "Prometheus",
        "gridPos": {
          "h": 6,
          "w": 24,
          "x": 0,
          "y": 4
        },
        "targets": [
          {
            "expr": "health_component_status",
            "refId": "A",
            "format": "table",
            "instant": true
          }
        ],
        "options": {
          "showHeader": true,
          "sortBy": []
        },
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {},
              "indexByName": {},
              "renameByName": {
                "component": "Component",
                "status": "Status",
                "message": "Message",
                "check_count": "Checks",
                "error_count": "Errors"
              }
            }
          }
        ]
      },
      {
        "id": 6,
        "title": "Guard Health Status",
        "type": "table",
        "datasource": "Prometheus",
        "gridPos": {
          "h": 6,
          "w": 12,
          "x": 0,
          "y": 10
        },
        "targets": [
          {
            "expr": "health_component_status{component=~\"guard_.*\"}",
            "refId": "A",
            "format": "table",
            "instant": true
          }
        ],
        "options": {
          "showHeader": true,
          "sortBy": []
        },
        "transformations": [
          {
            "id": "organize",
            "options": {
              "renameByName": {
                "component": "Guard",
                "status": "Status",
                "error_count": "Errors"
              }
            }
          }
        ]
      },
      {
        "id": 7,
        "title": "Memory & CPU Usage",
        "type": "graph",
        "datasource": "Prometheus",
        "gridPos": {
          "h": 6,
          "w": 12,
          "x": 12,
          "y": 10
        },
        "targets": [
          {
            "expr": "health_memory_percent",
            "refId": "A",
            "legendFormat": "Memory %"
          },
          {
            "expr": "health_cpu_percent",
            "refId": "B",
            "legendFormat": "CPU %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "showPoints": "auto",
              "spanNulls": false
            },
            "unit": "percent",
            "max": 100
          }
        }
      },
      {
        "id": 8,
        "title": "Ready Check History (5min)",
        "type": "graph",
        "datasource": "Prometheus",
        "gridPos": {
          "h": 4,
          "w": 12,
          "x": 0,
          "y": 16
        },
        "targets": [
          {
            "expr": "rate(health_ready[5m])",
            "refId": "A",
            "legendFormat": "Ready state changes/sec"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "showPoints": "auto"
            }
          }
        }
      },
      {
        "id": 9,
        "title": "Health Check Total Errors",
        "type": "graph",
        "datasource": "Prometheus",
        "gridPos": {
          "h": 4,
          "w": 12,
          "x": 12,
          "y": 16
        },
        "targets": [
          {
            "expr": "increase(health_component_errors_total[5m])",
            "refId": "A",
            "legendFormat": "Errors in 5min - {{component}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "showPoints": "auto"
            },
            "unit": "short"
          }
        }
      }
    ],
    "refresh": "10s",
    "schemaVersion": 36,
    "style": "dark",
    "templating": {
      "list": [
        {
          "current": {
            "selected": false,
            "text": "5m",
            "value": "5m"
          },
          "hide": 0,
          "includeAll": false,
          "label": "Time Range",
          "multi": false,
          "name": "time_range",
          "options": [
            {
              "selected": true,
              "text": "5m",
              "value": "5m"
            },
            {
              "selected": false,
              "text": "15m",
              "value": "15m"
            },
            {
              "selected": false,
              "text": "1h",
              "value": "1h"
            }
          ],
          "sort": 0,
          "type": "custom"
        }
      ]
    },
    "time": {
      "from": "now-1h",
      "to": "now"
    }
  }
}
